   "source": [
    "import xmlrpc.client\n",
    "\n",
    "server = xmlrpc.client.ServerProxy(\"http://localhost:8000/\")\n",
    "\n",
    "num = int(input(\"Enter a number: \"))\n",
    "result = server.factorial(num)\n",
    "\n",
    "print(\"Factorial of\", num, \"is:\", result)"
   ]
